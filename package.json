{
  "name": "monorepo",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently --kill-others --raw \"npm run dev --prefix apps/web\" \"npm run dev --prefix apps/api\"",
    "build": "concurrently --raw \"npm run build --prefix apps/web\"",
    "start": "npm run start --prefix apps/api",
    "lint": "concurrently --raw \"npm run lint --prefix apps/web\"",
    "migrate": "npm run migrate --prefix apps/api"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "concurrently": "^9.1.2"
  },
  "workspaces": [
    "apps/*"
  ]
}
